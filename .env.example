# ════════════════════════════════════════════════════════════════════════════════
# SafeStreets Backend Environment Configuration
# ════════════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in the actual values for your deployment.
# NEVER commit the actual .env file to version control!
#
# Users of the SafeStreets app don't need any API keys.
# Everything is handled through this backend API.
#
# ════════════════════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────────────────
# DATABASE
# ──────────────────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://username:password@hostname:port/database
# For local development: postgresql://localhost/safestreets
#
DATABASE_URL=postgresql://username:password@hostname:5432/safestreets

# ──────────────────────────────────────────────────────────────────────────────
# AI SPAM FILTERING (Groq)
# ──────────────────────────────────────────────────────────────────────────────
# Get your API key from: https://console.groq.com/keys
# If not provided, spam filtering will be disabled (all reports will be flagged for manual review)
#
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────────────────────────────────────
# ADMIN KEY
# ──────────────────────────────────────────────────────────────────────────────
# Secret key for accessing protected admin endpoints like /api/reports/flagged
# Must be sent in the X-Admin-Key header
# In production, use a strong random value (use `openssl rand -hex 32` to generate)
#
ADMIN_KEY=your_strong_random_admin_key_here
